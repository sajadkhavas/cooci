# Winimi Bakery frontend virtual host
# Replace the certificate paths after Certbot issues the production certificate.

server {
    listen 80;
    listen [::]:80;
    server_name winimibakery.com www.winimibakery.com;

    location /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://winimibakery.com$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.winimibakery.com;

    ssl_certificate /etc/letsencrypt/live/winimibakery.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/winimibakery.com/privkey.pem;

    return 301 https://winimibakery.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name winimibakery.com;

    root /var/www/winimi/frontend/current/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/winimibakery.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/winimibakery.com/privkey.pem;

    server_tokens off;
    charset utf-8;

    # Enable only after HTTPS works correctly for the production domain and subdomains.
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    add_header X-Frame-Options "DENY" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-site" always;

    # Start with a report-only CSP during production smoke tests, then enforce it.
    add_header Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://api.winimibakery.com; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests" always;

    location = /index.html {
        add_header Cache-Control "no-cache, must-revalidate" always;
        try_files $uri =404;
    }

    location = /sw.js {
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Service-Worker-Allowed "/" always;
        try_files $uri =404;
    }

    location = /manifest.webmanifest {
        default_type application/manifest+json;
        add_header Cache-Control "public, max-age=3600" always;
        try_files $uri =404;
    }

    location = /offline.html {
        add_header Cache-Control "public, max-age=86400" always;
        try_files $uri =404;
    }

    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        try_files $uri =404;
        access_log off;
    }

    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, must-revalidate" always;
    }

    location ~ /\. {
        deny all;
    }

    client_max_body_size 2m;
}
