# Render with scripts/render-frontend-nginx.mjs before installation.

upstream winimi_ssr {
    server __SSR_UPSTREAM__;
    keepalive 32;
}

server {
    listen __HTTP_PORT__;
    listen [::]:__HTTP_PORT__;
    server_name __SERVER_NAMES__;

    location /.well-known/acme-challenge/ {
        root __ACME_ROOT__;
    }

    location / {
        return 301 https://__CANONICAL_HOST____HTTPS_REDIRECT_PORT__$request_uri;
    }
}

server {
    listen __HTTPS_PORT__ ssl http2;
    listen [::]:__HTTPS_PORT__ ssl http2;
    server_name __SERVER_NAMES__;

    root __FRONTEND_ROOT__/current/app/build/client;

    ssl_certificate __TLS_CERTIFICATE__;
    ssl_certificate_key __TLS_CERTIFICATE_KEY__;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    server_tokens off;
    charset utf-8;
    etag on;

    gzip on;
    gzip_vary on;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types
        application/javascript
        application/json
        application/manifest+json
        application/xml
        image/svg+xml
        text/css
        text/html
        text/javascript
        text/plain
        text/xml;

    include __SECURITY_HEADERS_INCLUDE__;

    location = /__frontend_health {
        default_type application/json;
        include __SECURITY_HEADERS_INCLUDE__;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        return 200 '{"status":"ok","surface":"winimi-nginx"}';
    }

    location = /__ssr_health {
        proxy_pass http://winimi_ssr;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location = /sw.js {
        default_type application/javascript;
        include __SECURITY_HEADERS_INCLUDE__;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Service-Worker-Allowed "/" always;
        try_files $uri =404;
    }

    location = /manifest.webmanifest {
        default_type application/manifest+json;
        include __SECURITY_HEADERS_INCLUDE__;
        add_header Cache-Control "no-cache, must-revalidate" always;
        try_files $uri =404;
    }

    location = /offline.html {
        include __SECURITY_HEADERS_INCLUDE__;
        include __STATIC_CSP_INCLUDE__;
        add_header Cache-Control "no-cache, must-revalidate" always;
        try_files $uri =404;
    }

    location ^~ /icons/ {
        include __SECURITY_HEADERS_INCLUDE__;
        add_header Cache-Control "public, max-age=86400, stale-while-revalidate=604800" always;
        try_files $uri =404;
        access_log off;
    }

    location ^~ /assets/ {
        include __SECURITY_HEADERS_INCLUDE__;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        try_files $uri =404;
        access_log off;
    }

    location ~* \.(?:map|env|key|pem|log|sql|sqlite|bak)$ {
        return 404;
    }

    location ~ /\. {
        return 404;
    }

    location / {
        proxy_pass http://winimi_ssr;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_read_timeout 60s;
    }

    client_max_body_size 2m;
}
