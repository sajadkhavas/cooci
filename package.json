    "audit:phase19": "node scripts/audit-phase19-production-preparation.mjs",
    "env:production:validate": "node scripts/validate-production-env.mjs deploy/frontend.production.env.schema.json deploy/frontend.production.env.example",
    "release:create": "node scripts/create-frontend-release.mjs",
    "release:verify": "node scripts/verify-frontend-release.mjs",
