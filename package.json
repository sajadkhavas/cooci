{
  "name": "winimi-bakery-storefront",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev --host 0.0.0.0 --port 8080",
    "build": "react-router build && vite build --config vite.ssr-server.config.ts && node scripts/generate-service-worker.mjs",
    "postbuild": "node scripts/audit-performance.mjs",
