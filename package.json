    "test:e2e": "playwright test --config=e2e/playwright.config.mjs --max-failures=1",
    "lint": "eslint .",
    "typecheck": "npm run typegen && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "check": "npm run audit:launch && npm run audit:integration && npm run audit:acceptance && npm run audit:brand && npm run audit:phase1 && npm run audit:phase2 && npm run audit:phase3 && npm run audit:phase4 && npm run audit:phase5 && npm run audit:phase6 && npm run audit:phase7 && npm run audit:phase8 && npm run audit:phase9 && npm run audit:runtime && npm run audit:ssr && npm run audit:phase10-2 && npm run audit:phase10-3 && npm run audit:phase10-4 && npm run audit:phase10-5 && npm run audit:phase10-6 && npm run audit:phase10-7 && npm run audit:phase10-8 && npm run audit:phase10-9 && npm run audit:phase19 && npm run env:production:validate && npm run audit:frontend && npm run audit:accessibility && npm run audit:content && npm run audit:modern-ui && npm run test:unit && npm run lint && npm run typecheck && npm run build",
    "preview": "node build/runtime/server.mjs",
    "typegen": "react-router typegen",
    "postinstall": "node scripts/patch-react-router-dev-module-sync.mjs",
    "audit:ssr": "node scripts/audit-frontend-phase-10-1.mjs",
    "audit:phase10-2": "node scripts/audit-frontend-phase-10-2.mjs",
    "audit:phase10-3": "node scripts/audit-frontend-phase-10-3.mjs",
    "audit:phase10-4": "node scripts/audit-frontend-phase-10-4.mjs",
    "audit:phase10-5": "node scripts/audit-frontend-phase-10-5.mjs",
    "audit:phase10-6": "node scripts/audit-frontend-phase-10-6.mjs",
    "audit:phase10-7": "node scripts/audit-frontend-phase-10-7.mjs",
    "audit:phase10-8": "node scripts/audit-frontend-phase-10-8.mjs",
    "audit:phase10-9": "node scripts/audit-frontend-phase-10-9.mjs"
