    "audit:modern-ui": "node scripts/audit-modern-ui.mjs",
    "audit:brand": "node scripts/audit-brand-system.mjs",
    "audit:phase1": "node scripts/audit-frontend-phase-1.mjs",
    "audit:phase2": "node scripts/audit-frontend-phase-2.mjs",
    "audit:phase3": "node scripts/audit-frontend-phase-3.mjs",
    "audit:phase4": "node scripts/audit-frontend-phase-4.mjs",
    "audit:phase5": "node scripts/audit-frontend-phase-5.mjs",
    "audit:phase6": "node scripts/audit-frontend-phase-6.mjs",
