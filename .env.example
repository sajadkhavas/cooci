# Public site URL used by SEO/sitemap scripts
SITE_URL=https://winimibakery.com

# Enable backend-powered catalog and checkout when Laravel API is ready
VITE_USE_BACKEND=false
VITE_API_BASE_URL=https://api.winimibakery.com

# Payment provider identifier used by the frontend request payload
# Supported frontend type values: gateway-placeholder, zarinpal, idpay, nextpay
VITE_PAYMENT_PROVIDER=gateway-placeholder
