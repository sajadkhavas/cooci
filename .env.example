# Public storefront and canonical origin
SITE_URL=https://winimibakery.com
VITE_SITE_ORIGIN=https://winimibakery.com

# Frozen Laravel API contract used by every production dynamic flow
VITE_USE_BACKEND=true
VITE_API_BASE_URL=https://api.winimibakery.com

# Browser-only simulators are forbidden outside explicit local development
VITE_ALLOW_DEV_MOCKS=false
VITE_AUTH_MODE=disabled
VITE_PAYMENT_MODE=disabled

# When VITE_USE_BACKEND=true, authentication and payment modes are selected from
# the secure server contract. Mock values are only honored in a Vite DEV build
# when VITE_ALLOW_DEV_MOCKS=true is also set locally.

# Never expose SMS provider keys, Zarinpal merchant IDs, API keys, eNAMAD code,
# payment verification data or any other secret through VITE_* variables.
