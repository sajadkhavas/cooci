# Public site URL used by SEO/sitemap scripts and canonical tags
SITE_URL=https://winimibakery.com
VITE_SITE_ORIGIN=https://winimibakery.com

# Laravel API used for catalog, checkout, orders and payment verification
VITE_USE_BACKEND=false
VITE_API_BASE_URL=https://api.winimibakery.com

# Frontend payment mode
# backend  -> selected automatically when VITE_USE_BACKEND=true
# mock     -> development-only local payment simulator; no money is transferred
# disabled -> safest default until Laravel payment endpoints are available
VITE_PAYMENT_MODE=disabled

# Never expose Zarinpal merchant IDs, API keys or verification secrets through VITE_*.
# Those values belong only in the Laravel server environment.
