# Public site URL used by SEO/sitemap scripts and canonical tags
SITE_URL=https://winimibakery.com
VITE_SITE_ORIGIN=https://winimibakery.com

# Enable backend-powered catalog and checkout when Laravel API is ready
VITE_USE_BACKEND=false
VITE_API_BASE_URL=https://api.winimibakery.com

# Payment provider (client-side selector)
# Supported: gateway-placeholder, zarinpal, idpay, nextpay
VITE_PAYMENT_PROVIDER=zarinpal

# Zarinpal client-side adapter — leave empty to run in simulation mode
VITE_ZARINPAL_MERCHANT_ID=
VITE_ZARINPAL_SANDBOX=true
